{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://auraqa.io/schemas/audit_log.json",
  "title": "AuditLogEntry",
  "description": "JSON Schema for the audit log entry sent to Jira.",
  "type": "object",
  "required": [
    "audit_id",
    "test_case_id",
    "test_suite_id",
    "original_selector",
    "status"
  ],
  "properties": {
    "audit_id": {
      "type": "string",
      "description": "Unique audit entry identifier"
    },
    "test_case_id": {
      "type": "string",
      "description": "Associated test case"
    },
    "test_suite_id": {
      "type": "string",
      "description": "Associated test suite"
    },
    "original_selector": {
      "type": "string",
      "description": "Broken selector"
    },
    "healed_selector": {
      "type": ["string", "null"],
      "description": "Healed selector if found"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Final confidence score"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "analyzing", "generating", "validating", "healed", "retrying", "escalated", "failed"]
    },
    "drift_type": {
      "type": ["string", "null"],
      "enum": [
        "id_rename", "class_swap", "nesting_change",
        "attribute_removal", "tag_change", "text_change",
        "sibling_reorder", "compound_shift", null
      ]
    },
    "attempt_count": {
      "type": "integer",
      "minimum": 1
    },
    "execution_time_ms": {
      "type": "number",
      "minimum": 0
    },
    "page_url": {
      "type": "string"
    },
    "environment": {
      "type": "string"
    },
    "error_message": {
      "type": "string"
    },
    "scoring_breakdown": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "jira_issue_key": {
      "type": ["string", "null"],
      "description": "Created Jira issue key"
    },
    "jira_priority": {
      "type": "string",
      "enum": ["Critical", "High", "Medium", "Low"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
