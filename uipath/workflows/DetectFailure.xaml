<!-- /// uipath/workflows/DetectFailure.xaml — Capture failure details and build TestFailurePayload -->
<Activity mc:Ignorable="sap sap2010 sads" x:Class="AuraQA.DetectFailure"
  xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
  xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
  xmlns:sads="http://schemas.microsoft.com/netfx/2010/xaml/activities/debugger"
  xmlns:scg="clr-namespace:System.Collections.Generic;assembly=mscorlib"
  xmlns:ui="http://schemas.uipath.com/workflow/activities"
  xmlns:ua="http://schemas.uipath.com/workflow/activities/uiautomation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ════════════════════════════════════════════════════════ -->
  <!-- Arguments -->
  <!-- ════════════════════════════════════════════════════════ -->
  <x:Members>
    <x:Property Name="in_ErrorMessage" Type="InArgument(x:String)" />
    <x:Property Name="in_TargetUrl" Type="InArgument(x:String)" />
    <x:Property Name="in_TestCaseId" Type="InArgument(x:String)" />
    <x:Property Name="in_TestSuiteId" Type="InArgument(x:String)" />
    <x:Property Name="in_DOMSnapshot" Type="InArgument(x:String)" />
    <x:Property Name="out_FailurePayloadJson" Type="OutArgument(x:String)" />
  </x:Members>

  <Sequence DisplayName="DetectFailure Sequence" sap2010:WorkflowViewState.IdRef="DetectFailureSequence_1">

    <Sequence.Variables>
      <Variable x:TypeArguments="x:String" Name="var_ErrorMessage" />
      <Variable x:TypeArguments="x:String" Name="var_TargetUrl" />
      <Variable x:TypeArguments="x:String" Name="var_TestCaseId" />
      <Variable x:TypeArguments="x:String" Name="var_TestSuiteId" />
      <Variable x:TypeArguments="x:String" Name="var_DOMSnapshot" Default="" />
      <Variable x:TypeArguments="x:String" Name="var_ScreenshotBase64" Default="" />
      <Variable x:TypeArguments="x:String" Name="var_BrokenSelector" Default="" />
      <Variable x:TypeArguments="x:String" Name="var_SelectorType" Default="css" />
      <Variable x:TypeArguments="x:String" Name="var_Timestamp" />
      <Variable x:TypeArguments="x:String" Name="var_FailurePayloadJson" />
      <Variable x:TypeArguments="x:String" Name="var_ScreenshotFilePath" Default="" />
    </Sequence.Variables>

    <!-- Initialize from arguments -->
    <Assign DisplayName="Set ErrorMessage">
      <Assign.To><OutArgument x:TypeArguments="x:String">[var_ErrorMessage]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[in_ErrorMessage]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Set TargetUrl">
      <Assign.To><OutArgument x:TypeArguments="x:String">[var_TargetUrl]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[in_TargetUrl]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Set TestCaseId">
      <Assign.To><OutArgument x:TypeArguments="x:String">[var_TestCaseId]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[in_TestCaseId]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Set TestSuiteId">
      <Assign.To><OutArgument x:TypeArguments="x:String">[var_TestSuiteId]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[in_TestSuiteId]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Set DOMSnapshot from input">
      <Assign.To><OutArgument x:TypeArguments="x:String">[var_DOMSnapshot]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[in_DOMSnapshot]</InArgument></Assign.Value>
    </Assign>

    <ui:LogMessage DisplayName="Log DetectFailure Start" Level="Info"
      Message="[String.Format(&quot;DetectFailure started — TC: {0}, Error: {1}&quot;, var_TestCaseId, var_ErrorMessage)]" />

    <!-- ════════════════════════════════════════════════════════ -->
    <!-- Capture timestamp -->
    <!-- ════════════════════════════════════════════════════════ -->
    <Assign DisplayName="Capture UTC Timestamp">
      <Assign.To><OutArgument x:TypeArguments="x:String">[var_Timestamp]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[DateTime.UtcNow.ToString("o")]</InArgument></Assign.Value>
    </Assign>

    <!-- ════════════════════════════════════════════════════════ -->
    <!-- Extract broken selector from error message -->
    <!-- ════════════════════════════════════════════════════════ -->
    <Assign DisplayName="Extract Broken Selector from Error">
      <Assign.To><OutArgument x:TypeArguments="x:String">[var_BrokenSelector]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[If(var_ErrorMessage.Contains("Selector"), var_ErrorMessage.Substring(var_ErrorMessage.IndexOf("Selector")), var_ErrorMessage)]</InArgument></Assign.Value>
    </Assign>

    <!-- ════════════════════════════════════════════════════════ -->
    <!-- Determine selector type from the broken selector text -->
    <!-- ════════════════════════════════════════════════════════ -->
    <If DisplayName="Determine Selector Type" Condition="[var_BrokenSelector.Contains(&quot;/&quot;)]">
      <If.Then>
        <Assign DisplayName="Set XPath Type">
          <Assign.To><OutArgument x:TypeArguments="x:String">[var_SelectorType]</OutArgument></Assign.To>
          <Assign.Value><InArgument x:TypeArguments="x:String">xpath</InArgument></Assign.Value>
        </Assign>
      </If.Then>
      <If.Else>
        <If DisplayName="Check data-testid" Condition="[var_BrokenSelector.Contains(&quot;data-testid&quot;)]">
          <If.Then>
            <Assign DisplayName="Set data-testid Type">
              <Assign.To><OutArgument x:TypeArguments="x:String">[var_SelectorType]</OutArgument></Assign.To>
              <Assign.Value><InArgument x:TypeArguments="x:String">data-testid</InArgument></Assign.Value>
            </Assign>
          </If.Then>
          <If.Else>
            <Assign DisplayName="Set CSS Type">
              <Assign.To><OutArgument x:TypeArguments="x:String">[var_SelectorType]</OutArgument></Assign.To>
              <Assign.Value><InArgument x:TypeArguments="x:String">css</InArgument></Assign.Value>
            </Assign>
          </If.Else>
        </If>
      </If.Else>
    </If>

    <!-- ════════════════════════════════════════════════════════ -->
    <!-- Take screenshot (base64-encoded) -->
    <!-- ════════════════════════════════════════════════════════ -->
    <TryCatch DisplayName="Screenshot Capture Try-Catch">
      <TryCatch.Try>
        <Sequence DisplayName="Capture Screenshot">
          <!-- Save screenshot to temp file -->
          <Assign DisplayName="Set Screenshot File Path">
            <Assign.To><OutArgument x:TypeArguments="x:String">[var_ScreenshotFilePath]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:String">[System.IO.Path.Combine(System.IO.Path.GetTempPath(), String.Format("auraqa_screenshot_{0}.png", var_TestCaseId))]</InArgument></Assign.Value>
          </Assign>

          <ua:TakeScreenshot DisplayName="Take Screenshot"
            FileName="[var_ScreenshotFilePath]"
            xmlns:ua="http://schemas.uipath.com/workflow/activities/uiautomation">
            <ua:TakeScreenshot.Target>
              <ua:Target>
                <ua:Target.Selector>
                  <ua:Selector Text="&lt;html /&gt;" />
                </ua:Target.Selector>
              </ua:Target>
            </ua:TakeScreenshot.Target>
          </ua:TakeScreenshot>

          <!-- Convert screenshot to base64 -->
          <Assign DisplayName="Convert Screenshot to Base64">
            <Assign.To><OutArgument x:TypeArguments="x:String">[var_ScreenshotBase64]</OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:String">[Convert.ToBase64String(System.IO.File.ReadAllBytes(var_ScreenshotFilePath))]</InArgument></Assign.Value>
          </Assign>

          <ui:LogMessage DisplayName="Log Screenshot Captured" Level="Info"
            Message="Screenshot captured and base64-encoded." />
        </Sequence>
      </TryCatch.Try>
      <TryCatch.Catches>
        <Catch x:TypeArguments="s:Exception" xmlns:s="clr-namespace:System;assembly=mscorlib">
          <ActivityAction x:TypeArguments="s:Exception">
            <ActivityAction.Argument>
              <DelegateInArgument x:TypeArguments="s:Exception" Name="screenshotException" />
            </ActivityAction.Argument>
            <Sequence DisplayName="Handle Screenshot Failure">
              <Assign DisplayName="Set Screenshot to null">
                <Assign.To><OutArgument x:TypeArguments="x:String">[var_ScreenshotBase64]</OutArgument></Assign.To>
                <Assign.Value><InArgument x:TypeArguments="x:String" /></Assign.Value>
              </Assign>
              <ui:LogMessage DisplayName="Log Screenshot Warning" Level="Warn"
                Message="[String.Format(&quot;Screenshot capture failed — {0}. Continuing without screenshot.&quot;, screenshotException.Message)]" />
            </Sequence>
          </ActivityAction>
        </Catch>
      </TryCatch.Catches>
    </TryCatch>

    <!-- ════════════════════════════════════════════════════════ -->
    <!-- Retrieve DOM Snapshot if not already provided -->
    <!-- ════════════════════════════════════════════════════════ -->
    <If DisplayName="Check if DOM Snapshot needed" Condition="[String.IsNullOrEmpty(var_DOMSnapshot)]">
      <If.Then>
        <TryCatch DisplayName="DOM Snapshot Try-Catch">
          <TryCatch.Try>
            <ua:GetFullText DisplayName="Get DOM Snapshot from Page"
              xmlns:ua="http://schemas.uipath.com/workflow/activities/uiautomation">
              <ua:GetFullText.Target>
                <ua:Target>
                  <ua:Target.Selector>
                    <ua:Selector Text="&lt;html /&gt;&lt;webctrl tag='html' /&gt;" />
                  </ua:Target.Selector>
                </ua:Target>
              </ua:GetFullText.Target>
              <ua:GetFullText.Value>
                <OutArgument x:TypeArguments="x:String">[var_DOMSnapshot]</OutArgument>
              </ua:GetFullText.Value>
            </ua:GetFullText>
          </TryCatch.Try>
          <TryCatch.Catches>
            <Catch x:TypeArguments="s:Exception" xmlns:s="clr-namespace:System;assembly=mscorlib">
              <ActivityAction x:TypeArguments="s:Exception">
                <ActivityAction.Argument>
                  <DelegateInArgument x:TypeArguments="s:Exception" Name="domException" />
                </ActivityAction.Argument>
                <Sequence DisplayName="Handle DOM Capture Failure">
                  <Assign DisplayName="Set Empty DOM">
                    <Assign.To><OutArgument x:TypeArguments="x:String">[var_DOMSnapshot]</OutArgument></Assign.To>
                    <Assign.Value><InArgument x:TypeArguments="x:String">&lt;html&gt;&lt;body&gt;DOM capture failed&lt;/body&gt;&lt;/html&gt;</InArgument></Assign.Value>
                  </Assign>
                  <ui:LogMessage DisplayName="Log DOM Warning" Level="Warn"
                    Message="[String.Format(&quot;DOM snapshot capture failed — {0}&quot;, domException.Message)]" />
                </Sequence>
              </ActivityAction>
            </Catch>
          </TryCatch.Catches>
        </TryCatch>
      </If.Then>
    </If>

    <!-- ════════════════════════════════════════════════════════ -->
    <!-- Build TestFailurePayload JSON (per failure_payload.json schema) -->
    <!-- ════════════════════════════════════════════════════════ -->
    <Assign DisplayName="Build FailurePayload JSON">
      <Assign.To><OutArgument x:TypeArguments="x:String">[var_FailurePayloadJson]</OutArgument></Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">[String.Format("{{""test_case_id"":""{0}"",""test_suite_id"":""{1}"",""broken_selector"":""{2}"",""selector_type"":""{3}"",""dom_snapshot"":""{4}"",""original_element_attributes"":{{""tag"":""button""}},""page_url"":""{5}"",""screenshot_base64"":""{6}"",""error_message"":""{7}"",""timestamp"":""{8}"",""environment"":""staging"",""retry_count"":0}}", var_TestCaseId, var_TestSuiteId, var_BrokenSelector.Replace("""", "\"""), var_SelectorType, var_DOMSnapshot.Replace("""", "\""").Replace(vbCr, "").Replace(vbLf, ""), var_TargetUrl, If(String.IsNullOrEmpty(var_ScreenshotBase64), "null", var_ScreenshotBase64), var_ErrorMessage.Replace("""", "\"""), var_Timestamp)]</InArgument>
      </Assign.Value>
    </Assign>

    <ui:LogMessage DisplayName="Log Payload Built" Level="Info"
      Message="[String.Format(&quot;FailurePayload built — TC: {0}, Selector: {1}, Type: {2}&quot;, var_TestCaseId, var_BrokenSelector, var_SelectorType)]" />

    <!-- ════════════════════════════════════════════════════════ -->
    <!-- Set output arguments -->
    <!-- ════════════════════════════════════════════════════════ -->
    <Assign DisplayName="Output FailurePayloadJson">
      <Assign.To><OutArgument x:TypeArguments="x:String">[out_FailurePayloadJson]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[var_FailurePayloadJson]</InArgument></Assign.Value>
    </Assign>

    <ui:LogMessage DisplayName="Log DetectFailure End" Level="Info"
      Message="DetectFailure workflow completed." />

  </Sequence>
</Activity>
